# 프로젝트 전용 제외 항목
models/*.pt
models/*.pth
data/raw/*
data/labeled/*
data/augmented/*
!data/raw/.gitkeep
!data/labeled/.gitkeep
!data/augmented/.gitkeep

# PyInstaller 빌드 결과물
dist/
build/
*.spec

# 설정 파일 (민감 정보 포함 가능)
configs/*.json
!configs/.gitkeep

# Python 캐시 파일
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/