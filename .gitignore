# 프로젝트 전용 제외 항목
models/*.pt
models/*.pth
data/raw/*
data/labeled/*
data/augmented/*
!data/raw/.gitkeep
!data/labeled/.gitkeep
!data/augmented/.gitkeep

# PyInstaller 빌드 결과물
dist/
build/
*.spec

# 설정 파일 (민감 정보 포함 가능)
configs/*.json
!configs/.gitkeep

# Python 캐시 파일
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# MVTec 데이터셋 (대용량 — Git 추적 제외)
data/mvtec/

# 학습된 모델 결과물 (대용량 — Git 추적 제외)
models/patchcore_screw/

# 수집한 원본 이미지 데이터 (대용량)
data/
deploy_models/

vision-inspection-deploy/
deploy_models/
