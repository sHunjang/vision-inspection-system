# ── Python 캐시 ──────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ── PyInstaller (런처 방식으로 전환, 더 이상 사용 안 함) ──
dist/
build/
*.spec

# ── 대용량 데이터 (Git 추적 제외) ────────────────
data/mvtec/
data/raw/*/
data/custom/
!data/raw/.gitkeep

# ── 학습된 모델 결과물 (대용량) ──────────────────
models/patchcore_screw/
deploy_models/

# ── 배포 패키지 (스크립트로 재생성 가능) ─────────
vision-inspection-deploy/

# ── 설정 파일 (민감 정보 포함 가능) ─────────────
configs/*.json
!configs/.gitkeep

# ── DB 파일 ──────────────────────────────────────
data/inspection.db

# ── 기타 ─────────────────────────────────────────
*.pt
*.pth